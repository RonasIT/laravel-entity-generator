{
  "name": "ronasit/laravel-entity-generator",
  "description": "Provided console command for generating entities.",
  "keywords": ["laravel", "entity generator"],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^10.48",
    "ronasit/laravel-helpers": "dev-master",
    "laravel/legacy-factories": ">=1.3.0",
    "ext-json": "*"
  },
  "require-dev": {
    "php-coveralls/php-coveralls": "^2.5",
    "mockery/mockery": "^1.4",
    "phpunit/phpunit": "^10.1",
    "mikey179/vfsstream": "^1.6.11",
    "php-mock/php-mock": "^2.4.1",
    "orchestra/testbench": "^8.23"
  },
  "autoload": {
    "psr-4": {
      "RonasIT\\Support\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "RonasIT\\Support\\Tests\\": "tests/",
      "RonasIT\\Support\\Tests\\Support\\": "tests/Support/"
    },
    "files": [
      "tests/TestCase.php"
    ]
  },
  "minimum-stability": "beta",
  "extra": {
    "laravel": {
      "providers": [
        "RonasIT\\Support\\EntityGeneratorServiceProvider"
      ]
    }
  }
}
