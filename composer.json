{
  "name": "ronasit/laravel-entity-generator",
  "description": "Provided console command for generating entities.",
  "keywords": ["laravel", "entity generator"],
  "license": "MIT",
  "authors": [
    {
      "name": "Roman Dubrovin",
      "email": "rdubrovin@ronasit.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/framework": ">=11.20",
    "ronasit/laravel-helpers": ">=3.5",
    "ext-json": "*",
    "doctrine/dbal": "^4.2",
    "winter/laravel-config-writer": ">=1.2.1"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24.0",
    "mockery/mockery": "^1.6.12",
    "phpunit/phpunit": ">=11",
    "php-coveralls/php-coveralls": "^2.7",
    "orchestra/testbench": ">=9.5.1",
    "mikey179/vfsstream": "^1.6.12",
    "php-mock/php-mock": "^2.5",
    "laravel/pint": "^1.27"
  },
  "autoload": {
    "psr-4": {
      "RonasIT\\EntityGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "RonasIT\\EntityGenerator\\Tests\\": "tests/",
      "RonasIT\\EntityGenerator\\Tests\\Support\\": "tests/Support/",
      "App\\Nova\\": "tests/Support/Nova/"
    },
    "files": [
      "tests/TestCase.php"
    ]
  },
  "minimum-stability": "beta",
  "extra": {
    "laravel": {
      "providers": [
        "RonasIT\\EntityGenerator\\EntityGeneratorServiceProvider"
      ]
    }
  }
}
